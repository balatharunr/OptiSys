<Page x:Class="OptiSys.App.Views.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:converters="clr-namespace:OptiSys.App.Converters"
        xmlns:viewModels="clr-namespace:OptiSys.App.ViewModels"
        xmlns:controls="clr-namespace:OptiSys.App.Views"
        xmlns:ux="clr-namespace:OptiSys.App.Controls"
            mc:Ignorable="d"
            Title="Cleanup"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True"
            FontFamily="Segoe UI Variable Text"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType"
            TextOptions.TextHintingMode="Fixed"
            RenderOptions.ClearTypeHint="Enabled"
            Background="{DynamicResource CleanupBackdropBrush}">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CleanupResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
                <Grid UseLayoutRounding="True"
                                        SnapsToDevicePixels="True"
                                        TextOptions.TextFormattingMode="Display"
                                        TextOptions.TextRenderingMode="ClearType">
                    <ScrollViewer x:Name="RootScrollViewer"
                      Margin="32"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      IsDeferredScrollingEnabled="False"
                      PanningMode="VerticalOnly"
                      PanningRatio="1"
                      IsManipulationEnabled="True"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True"
                      Focusable="False">
                <StackPanel MinWidth="760"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True">
        <controls:PageTitleBar Title="Cleanup operations"
                                Subtitle="{Binding Headline}"
                                IconGlyph="🧹"
                                Margin="0,0,0,24"/>
        <Border Background="{StaticResource CleanupSurfaceBrush}"
            BorderBrush="{StaticResource CleanupBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="28,24"
        Margin="0,0,0,24"
            Style="{StaticResource SetupPhaseContainerStyle}"
            Effect="{StaticResource SurfaceShadowEffect}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
            <Border Width="56"
                Height="56"
                VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A3A6E" Offset="0"/>
                                <GradientStop Color="#122848" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.CornerRadius>16</Border.CornerRadius>
                        <TextBlock Text="🧹"
                                   FontSize="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                        <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                        <TextBlock Text="Phase 1 — Configure scan"
                                   Foreground="{StaticResource CleanupAccentBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Opacity="0.9"/>
                        <TextBlock Text="Shape your cleanup preview"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Dial in scope, types, and filters — then preview what gets cleaned."
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>


        <Border Background="{StaticResource CleanupSurfaceBaseBrush}"
            BorderBrush="{StaticResource CleanupBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="28,24,28,20"
        Margin="0,0,0,28"
            Style="{StaticResource SetupPhaseContainerStyle}"
            Effect="{StaticResource SurfaceShadowEffect}">
                        <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Setup checklist"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"/>
                            <TextBlock Text="Confirm what the preview should include before you run it."
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                CornerRadius="8"
                                Padding="10,5"
                                VerticalAlignment="Center">
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource CleanupAccentBrush}">
                                <Run Text="5 filters"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <ux:AdaptiveTilePanel MinColumnWidth="300"
                                          MaxColumnWidth="520"
                                          MinColumns="1"
                                          MaxColumns="3"
                                          ColumnSpacing="16"
                                          RowSpacing="16"
                                          Padding="0">

                        <!-- ── Scope card ── -->
                        <Border Style="{StaticResource SetupCardStyle}"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            CornerRadius="8" Width="32" Height="32"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="📂" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Scope"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <TextBlock Text="What to scan"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Background="{StaticResource CleanupSurfaceBrush}"
                                        CornerRadius="8" Padding="12,10">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Include Downloads"
                                                  FontSize="13"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  IsChecked="{Binding IncludeDownloads, Mode=TwoWay}"/>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Include browser history"
                                                  FontSize="13"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  Margin="0,8,0,0"
                                                  ToolTip="Use the secure WebView2 API to clear Edge profiles when enabled."
                                                  IsChecked="{Binding IncludeBrowserHistory, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── Filter by type card ── -->
                        <Border Style="{StaticResource SetupCardStyle}"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            CornerRadius="8" Width="32" Height="32"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="🗂️" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Filter by type"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <TextBlock Text="Files, folders, or both"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding ItemKindOptions}"
                                          SelectedValuePath="Kind"
                                          SelectedValue="{Binding SelectedItemKind, Mode=TwoWay}"
                                          DisplayMemberPath="Label"
                                          Style="{StaticResource App.ComboBoxStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Extensions card ── -->
                        <Border Style="{StaticResource SetupCardStyle}"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            CornerRadius="8" Width="32" Height="32"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="🧩" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Extensions"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <TextBlock Text="Include or exclude file types"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding ExtensionFilterOptions}"
                                          SelectedValuePath="Mode"
                                          SelectedValue="{Binding SelectedExtensionFilterMode, Mode=TwoWay}"
                                          Style="{StaticResource App.ComboBoxStyle}"
                                          ToolTip="{Binding SelectedItem.Description, RelativeSource={RelativeSource Self}}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#94A3B8"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding ExtensionStatusText}"
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Top items card ── -->
                        <Border Style="{StaticResource SetupCardStyle}"
                                Margin="0,0,0,0"
                                MinWidth="300">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            CornerRadius="8" Width="32" Height="32"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="📊" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Top items"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <TextBlock Text="Cap preview results"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="{StaticResource CleanupSurfaceBrush}"
                                    CornerRadius="10"
                                    Padding="14,10"
                                    HorizontalAlignment="Center"
                                    MinWidth="200"
                                    Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Preview cap"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding PreviewCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                                 Style="{StaticResource App.TextBoxStyle}"
                                                 FontSize="22"
                                                 FontWeight="SemiBold"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 HorizontalContentAlignment="Center"
                                                 Padding="4"
                                                 MinHeight="40"/>
                                        <TextBlock Text="items"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Margin="0,0,0,8">
                                    <Slider Minimum="{Binding PreviewCountMinimum, Mode=OneWay}"
                                            Maximum="{Binding PreviewCountMaximum, Mode=OneWay}"
                                            Value="{Binding PreviewCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource CleanupSliderStyle}"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PreviewCountMinimum}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PreviewCountMaximum}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </Grid>
                                </StackPanel>

                                <UniformGrid Columns="3"
                                         Rows="2"
                                         Margin="0,4,0,0"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight">
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="25"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>25</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="50"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>50</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="100"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>100</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="1,000"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>1000</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="10,000"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>10000</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                    <Button Style="{StaticResource ChipButtonStyle}"
                                            Content="100,000"
                                            Command="{Binding ApplyPreviewPresetCommand}">
                                        <Button.CommandParameter>
                                            <sys:Int32>100000</sys:Int32>
                                        </Button.CommandParameter>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- ── Cache age filter card ── -->
                        <Border Style="{StaticResource SetupCardStyle}"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            CornerRadius="8" Width="32" Height="32"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="🕐" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Cache age filter"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <TextBlock Text="Protect recent data"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>

                                    <!-- Active / Inactive badge -->
                                    <Border Grid.Column="2" CornerRadius="6"
                                            Padding="8,3" VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3034D399"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedAgeFilter.Days}" Value="0">
                                                        <Setter Property="Background" Value="#30F59E0B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Active"/>
                                                    <Setter Property="Foreground" Value="{StaticResource CleanupAccentBrushSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedAgeFilter.Days}" Value="0">
                                                            <Setter Property="Text" Value="Off"/>
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <ComboBox ItemsSource="{Binding AgeFilterOptions}"
                                          SelectedItem="{Binding SelectedAgeFilter, Mode=TwoWay}"
                                          Style="{StaticResource App.ComboBoxStyle}"
                                          DisplayMemberPath="Label"/>
                                <TextBlock Text="{Binding SelectedAgeFilter.Description}"
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </ux:AdaptiveTilePanel>

                    <Expander Header="Advanced options"
                              Background="Transparent"
                              Foreground="{StaticResource CleanupSoftTextBrush}"
                              Margin="0,12,0,0">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource AdvancedCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Extension profile"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                    <TextBlock FontSize="12"
                                               Margin="0,4,0,8">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource CleanupMutedTextBrush}"/>
                                                <Setter Property="Text"
                                                        Value="Apply a preset list of extensions for quick filtering."/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExtensionSelectorEnabled}"
                                                                 Value="False">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource CleanupMutedTextBrush}"/>
                                                        <Setter Property="Text"
                                                                Value="Enable extension filtering above to choose a preset."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ComboBox ItemsSource="{Binding ExtensionProfiles}"
                                              SelectedItem="{Binding SelectedExtensionProfile, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Style="{StaticResource App.ComboBoxStyle}"
                                              IsEnabled="{Binding IsExtensionSelectorEnabled}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource AdvancedCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Custom extensions"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                                                                             Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                    <TextBlock Text="Separate values with commas, spaces, or semicolons."
                                               FontSize="12"
                                                                                             Foreground="{StaticResource CleanupMutedTextBrush}"
                                               Margin="0,4,0,8"/>
                                    <TextBox Text="{Binding CustomExtensionInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                             Style="{StaticResource App.TextBoxStyle}"
                                             IsEnabled="{Binding IsExtensionSelectorEnabled}"
                                             ToolTip="Separate extensions with commas, spaces, or semicolons."/>
                                </StackPanel>
                            </Border>


                        </StackPanel>
                    </Expander>

                            <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,24,0,0">
                            <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                Margin="0,0,10,0"/>
                            <Button Content="Reset filters"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                Background="{StaticResource CleanupSurfaceBrush}"
                                Margin="0,0,10,0"/>
                            <Button Content="Automation"
                                Style="{StaticResource CleanupAutomationButtonStyle}"
                                Command="{Binding ToggleAutomationPanelCommand}"
                                Margin="0,0,10,0">
                            <Button.IsEnabled>
                            <Binding Path="IsBusy" Converter="{StaticResource InverseBooleanConverter}"/>
                            </Button.IsEnabled>
                        </Button>
                        <Button Content="Run preview"
                            Background="{StaticResource CleanupAccentBrushSecondary}"
                            Foreground="#041225"
                            FontWeight="Semibold"
                            Padding="16,8"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding ShowPreviewConfirmationPopupCommand}"
                            Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="RunBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled"
                                                 Value="False">
                                            <Setter TargetName="RunBorder"
                                                    Property="Opacity"
                                                    Value="0.6"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="RunBorder"
                                                    Property="Background"
                            Value="#2DD4BF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.IsEnabled>
                                <Binding Path="IsBusy"
                                         Converter="{StaticResource InverseBooleanConverter}"/>
                            </Button.IsEnabled>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        <Border Background="{StaticResource CleanupSurfaceBaseBrush}"
            BorderBrush="{StaticResource CleanupBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
        Padding="0"
            Style="{StaticResource PreviewPhaseContainerStyle}"
            Effect="{StaticResource SurfaceShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                   Margin="24,20,24,12">
            <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Phase 2 — Preview results"
                                       FontSize="14"
                        Foreground="{StaticResource CleanupSoftTextBrush}"/>
                            <TextBlock Text="{Binding SummaryText}"
                                       FontSize="12"
                        Foreground="{StaticResource CleanupMutedTextBrush}"/>
                        </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                <Button Content="Back to setup"
                    Command="{Binding NavigateToSetupCommand}"
                    Style="{StaticResource FlatButtonStyle}"
                    Background="{StaticResource CleanupSurfaceBrush}"
                    Margin="0"
                    VerticalAlignment="Center"/>
            </StackPanel>
                    </DockPanel>

                    <StackPanel Grid.Row="2"
                                Margin="24,0,24,12">
            <Border Style="{StaticResource InlineToastStyle}"
                Background="{StaticResource CleanupSurfaceHighlightBrush}"
                BorderBrush="{StaticResource CleanupAccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
                <TextBlock Text="🆕"
                       FontSize="14"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RefreshToastText}"
                       FontSize="12"
              Foreground="{StaticResource CleanupSoftTextBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       MaxWidth="360"/>
                <Button Content="Dismiss"
                    Command="{Binding DismissRefreshToastCommand}"
                    Style="{StaticResource ChipButtonStyle}"
                    Margin="16,0,0,0"
                    Padding="12,4"/>
                </StackPanel>
            </Border>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Selected"
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       Margin="0,0,8,8"/>
                            <TextBlock Text="{Binding SelectedItemCount, StringFormat={}{0:N0} files}"
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                       Margin="0,0,16,8"/>
                            <TextBlock Text="{Binding SelectedItemSizeMegabytes, StringFormat={}{0:F2} MB}"
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                       Margin="0,0,0,8"/>
                        </WrapPanel>
                        <WrapPanel>
                            <Button Content="Clear selection"
                                    Command="{Binding ClearCurrentSelectionCommand}"
                                    Padding="14,8"
                                    Cursor="Hand"
                                    BorderThickness="0"
                    Background="{StaticResource CleanupSurfaceHighlightBrush}"
                    Foreground="{StaticResource CleanupSoftTextBrush}"
                                    Margin="0,0,8,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ClearBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter TargetName="ClearBorder"
                                                        Property="Opacity"
                                                        Value="0.5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="ClearBorder"
                                                        Property="Background"
                                                        Value="{StaticResource CleanupAccentBrush}"/>
                                                <Setter Property="Foreground"
                                                        Value="#041225"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Select all"
                                    Command="{Binding SelectAllCurrentCommand}"
                                    Padding="14,8"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                    Foreground="{StaticResource CleanupSoftTextBrush}"
                                    Margin="0,0,8,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SelectBorder"
                                                Background="{TemplateBinding Background}"
