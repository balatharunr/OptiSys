                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="SelectBorder"
                                                        Property="Background"
                                                        Value="{StaticResource CleanupAccentBrush}"/>
                                                <Setter Property="Foreground"
                                                        Value="#041225"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Select all pages"
                                    Command="{Binding SelectAllPagesCommand}"
                                    Padding="14,8"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                    Foreground="{StaticResource CleanupSoftTextBrush}"
                                    Margin="0,0,8,8"
                                    ToolTip="Select every filtered item across all pages.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SelectAllPagesBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter TargetName="SelectAllPagesBorder"
                                                        Property="Opacity"
                                                        Value="0.5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="SelectAllPagesBorder"
                                                        Property="Background"
                                                        Value="{StaticResource CleanupAccentBrush}"/>
                                                <Setter Property="Foreground"
                                                        Value="#041225"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Delete selected"
                                    Command="{Binding DeleteSelectedCommand}"
                                    Background="#EF4444"
                                    Foreground="{StaticResource CleanupSoftTextBrush}"
                                    FontWeight="Semibold"
                                    Padding="16,8"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    Margin="0,0,8,8"
                                    ToolTip="Open confirmation to review and run cleanup for the selected items.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ActionBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled"
                                                     Value="False">
                                                <Setter TargetName="ActionBorder"
                                                        Property="Opacity"
                                                        Value="0.6"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="ActionBorder"
                                                        Property="Background"
                                                        Value="#DC2626"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </WrapPanel>
                    </StackPanel>

              <Grid Grid.Row="3"
                          Margin="16">
            <Border x:Name="CategoryListHost"
                Background="{StaticResource CleanupSurfaceBrush}"
                CornerRadius="10"
                Effect="{StaticResource CardShadowEffect}">
                            <ux:BubbleScrollListView x:Name="CategoryListView"
                                                     ItemsSource="{Binding Targets}"
                                                     SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource CleanupSoftTextBrush}"
                                                     Padding="12,12,12,4"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.CanContentScroll="True"
                                                     ScrollViewer.IsDeferredScrollingEnabled="False"
                                                     VirtualizingPanel.IsVirtualizing="True"
                                                     VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                                     VirtualizingPanel.IsContainerVirtualizable="True"
                                                     VirtualizingPanel.ScrollUnit="Pixel"
                                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                                     VirtualizingPanel.CacheLength="2"
                                                     VirtualizingPanel.CacheLengthUnit="Page"
                                                     ParentScrollViewerName="RootScrollViewer"
                                                     UseLayoutRounding="True"
                                                     SnapsToDevicePixels="True">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                            VirtualizingPanel.IsContainerVirtualizable="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling"
                                            VirtualizingPanel.ScrollUnit="Pixel"/>
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch"/>
                                        <Setter Property="Margin"
                                                Value="0,0,0,10"/>
                                        <Setter Property="Padding"
                                                Value="0"/>
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="BorderThickness"
                                                Value="0"/>
                                        <Setter Property="FocusVisualStyle"
                                                Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CleanupListCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                          Grid.Row="0"
                                                          Grid.RowSpan="4"
                                                          Grid.Column="0"
                                                          IsChecked="{Binding SelectionToggleState, Mode=TwoWay}"
                                                          IsThreeState="True"
                                                          Margin="0,2,16,0"
                                                          VerticalAlignment="Top"
                                                          FocusVisualStyle="{x:Null}"
                                                          Foreground="{StaticResource CleanupSoftTextBrush}"
                                                          ToolTip="Select or clear this entire category."/>
                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Top">
                                                    <Border Style="{StaticResource CategoryBadgeStyle}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Classification}"
                                                                   Foreground="{StaticResource CleanupAccentBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Category}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource CleanupSoftTextBrush}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Category}">
                                                        <TextBlock.FontSize>
                                                            <Binding Path="Category"
                                                                     Converter="{StaticResource CleanupTitleFontSizeConverter}"
                                                                     ConverterParameter="compact"/>
                                                        </TextBlock.FontSize>
                                                    </TextBlock>
                                                </StackPanel>
                                                <WrapPanel Grid.Row="1"
                                                           Grid.Column="1"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Left">
                                                    <Border Style="{StaticResource CleanupMetaChipStyle}"
                                                            Background="{StaticResource CleanupChipItemsBackgroundBrush}"
                                                            BorderBrush="{StaticResource CleanupChipItemsBorderBrush}">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource CleanupSoftTextBrush}">
                                                            <Run Text="Items"/>
                                                            <Run Text=" • "/>
                                                            <Run Text="{Binding RemainingItemCount, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Style="{StaticResource CleanupMetaChipStyle}"
                                                            Background="{StaticResource CleanupChipSizeBackgroundBrush}"
                                                            BorderBrush="{StaticResource CleanupChipSizeBorderBrush}">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource CleanupSoftTextBrush}">
                                                            <Run Text="Size"/>
                                                            <Run Text=" • "/>
                                                            <Run Text="{Binding RemainingSizeMegabytes, Mode=OneWay, StringFormat={}{0:F2} MB}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Margin="0,10,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="None"
                                                           Text="{Binding Path}"
                                                           ToolTip="{Binding Path}"/>
                                                <Button Grid.Row="3"
                                                        Grid.Column="1"
                                                        Content="View files"
                                                        Command="{Binding DataContext.ShowFilesPopupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,12,0,0"
                                                        Padding="16,8"
                                                        Cursor="Hand"
                                                        BorderThickness="0"
                                                        Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                                        Foreground="{StaticResource CleanupSoftTextBrush}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="ViewFilesBorder"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="📁"
                                                                               FontSize="12"
                                                                               Margin="0,0,8,0"
                                                                               VerticalAlignment="Center"/>
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="ViewFilesBorder"
                                                                            Property="Background"
                                                                            Value="{StaticResource CleanupAccentBrush}"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="#041225"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.IsEnabled>
                                    <Binding Path="IsBusy"
                                             Converter="{StaticResource InverseBooleanConverter}"/>
                                </ListView.IsEnabled>
                            </ux:BubbleScrollListView>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>

        <Border Background="#CC020B1F"
            Visibility="{Binding IsDeletionPreparationInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
            IsHitTestVisible="{Binding IsDeletionPreparationInProgress}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="5"
            Focusable="False">
            <Grid>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource CleanupSurfaceElevatedBrush}"
                        BorderBrush="{StaticResource CleanupBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="32"
                        Width="420"
                        Height="220"
                        Effect="{StaticResource SurfaceShadowEffect}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Width="52"
                                Height="52"
                                Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                CornerRadius="26"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <TextBlock Text="⌛"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Preparing deletion…"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"
                                   Margin="0,0,0,6"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Analyzing selected items"
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <ProgressBar Height="6"
                                     Width="300"
                                     IsIndeterminate="True"
                                     Foreground="{StaticResource CleanupProgressBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Background="#CC020B1F"
            Visibility="{Binding IsAutomationPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="3"
            Focusable="False">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False"
                  IsDeferredScrollingEnabled="False"
                  PanningMode="VerticalOnly"
                  IsManipulationEnabled="True"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True"
                  Focusable="False"
                  Padding="24">
            <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource CleanupAutomationPanelBrush}"
                BorderBrush="{StaticResource CleanupAutomationPanelBorderBrush}"
                BorderThickness="1.5"
                CornerRadius="28"
                Padding="36"
                MinWidth="640"
                MaxWidth="960"
                Effect="{StaticResource SurfaceShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            CornerRadius="16"
                            Background="{StaticResource CleanupSurfaceHighlightBrush}"
                            BorderBrush="{StaticResource CleanupBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="⚡"
                                   FontSize="24"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="16,0,16,0">
                        <TextBlock Text="Cleanup automation"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                        <TextBlock Text="Schedule lightweight cleanup runs without reopening the app."
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="2"
                                  Style="{StaticResource CleanupToggleSwitchStyle}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"
                                  IsChecked="{Binding IsCleanupAutomationEnabled, Mode=TwoWay}"/>
                    <Button Grid.Column="3"
                            Content="✕"
                            Command="{Binding CloseAutomationPanelCommand}"
                            Style="{StaticResource FlatButtonStyle}"
                            Padding="6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource CleanupMetaChipStyle}"
                        Background="#1E3154"
                        BorderBrush="#2E4D7A"
                        Margin="0,16,0,0">
                    <TextBlock Text="{Binding AutomationStatusMessage}"
                               Foreground="{StaticResource CleanupSoftTextBrush}"
                               TextWrapping="Wrap"
                               FontSize="13"/>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,20,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,16,0">
                        <TextBlock Text="Run cadence"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                        <ComboBox ItemsSource="{Binding AutomationIntervalOptions}"
                                  SelectedItem="{Binding SelectedAutomationInterval, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  Style="{StaticResource App.ComboBoxStyle}"
                                  Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding SelectedAutomationInterval.Description}"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,4,0,12"
                                   TextWrapping="Wrap"/>
                        <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                BorderBrush="{StaticResource CleanupBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Scope"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                <CheckBox Content="Include downloads"
                                          Margin="0,10,0,0"
                                          Style="{StaticResource App.CheckBoxStyle}"
                                          Foreground="{StaticResource CleanupSoftTextBrush}"
                                          IsChecked="{Binding AutomationIncludeDownloads, Mode=TwoWay}"/>
                                <CheckBox Content="Include browser history"
                                          Margin="0,6,0,0"
                                          Style="{StaticResource App.CheckBoxStyle}"
                                          Foreground="{StaticResource CleanupSoftTextBrush}"
                                          IsChecked="{Binding AutomationIncludeBrowserHistory, Mode=TwoWay}"/>
                                <TextBlock Text="Browser history clears Edge profiles using the Microsoft API."
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                BorderBrush="{StaticResource CleanupBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Top items per run"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                <TextBlock Text="Automation focuses on the heaviest entries first. Adjust the cap to balance speed and coverage."
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           Margin="0,6,0,12"
                                           TextWrapping="Wrap"/>
                                <Slider Minimum="{Binding AutomationTopItemMinimum, Mode=OneWay}"
                                        Maximum="{Binding AutomationTopItemMaximum, Mode=OneWay}"
                                        Value="{Binding AutomationTopItemCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="25"
                                        IsSnapToTickEnabled="True"
                                        Style="{StaticResource CleanupSliderStyle}"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding AutomationTopItemCountDisplay}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Margin="16,6,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource CleanupMutedTextBrush}">
                                        <Run Text="Range: "/>
                                        <Run Text="{Binding AutomationTopItemMinimum}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding AutomationTopItemMaximum}"/>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0">
                        <TextBlock Text="Deletion mode"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                        <ComboBox ItemsSource="{Binding AutomationDeletionModeOptions}"
                                  SelectedItem="{Binding SelectedAutomationDeletionMode, Mode=TwoWay}"
                                  Style="{StaticResource App.ComboBoxStyle}"
                                  Margin="0,6,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{Binding SelectedAutomationDeletionMode.Description}"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,4,0,16"
                                   TextWrapping="Wrap"/>
                        <Border Background="#1A2F52"
                                BorderBrush="#2E4D7A"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Heads-up"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                <TextBlock Text="Force delete takes ownership and may restart Explorer for stubborn files."
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Recycle bin mode is safest when reviewing deletions later."
                                           FontSize="11"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="3"
                        Background="#3A1F4D"
                        CornerRadius="8"
                        Padding="10,6"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasAutomationChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Pending changes will apply when you save."
                               Foreground="#F0ABFC"
                               FontWeight="SemiBold"/>
                </Border>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Apply settings"
                            Margin="0,0,12,0"
                            Command="{Binding ApplyCleanupAutomationCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
                                <Setter Property="Padding" Value="16,6"/>
                                <Setter Property="IsEnabled" Value="{Binding HasAutomationChanges}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutomationBusy}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Run now"
                            Margin="0,0,12,0"
                            Command="{Binding RunCleanupAutomationNowCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
                                <Setter Property="Padding" Value="16,6"/>
                                <Setter Property="IsEnabled" Value="{Binding IsCleanupAutomationEnabled}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAutomationChanges}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAutomationBusy}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Close"
                            Command="{Binding CloseAutomationPanelCommand}"
                            Style="{StaticResource FlatButtonStyle}"
                            Padding="16,6"/>
                </StackPanel>

                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            Margin="0,40,0,0"
                            VerticalAlignment="Bottom"
                            Visibility="{Binding IsAutomationBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Width="180"
                                 Height="4"
                                 IsIndeterminate="True"/>
                    <TextBlock Text="Working..."
                               Margin="12,0,0,0"
                               Foreground="{StaticResource CleanupMutedTextBrush}"/>
                </StackPanel>
            </Grid>
            </Border>
        </ScrollViewer>
    </Border>

    <Border Background="#AA020B1F"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Panel.ZIndex="2"
        Style="{StaticResource ConfirmationOverlayStyle}">
                <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource CleanupSurfaceBrush}"
                    BorderBrush="{StaticResource CleanupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="32"
                    MinWidth="760"
                    MaxWidth="1260"
                    Effect="{StaticResource SurfaceShadowEffect}"
                    Style="{StaticResource ConfirmationPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Phase 3 — Confirm cleanup"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource CleanupSoftTextBrush}"/>
                    <TextBlock Text="Review the impact before running cleanup."
                               FontSize="12"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               Margin="0,4,0,16"/>
                    <WrapPanel Margin="0,0,0,8">
                        <Border Style="{StaticResource SheetCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Items"
                                           FontSize="12"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                <TextBlock Text="{Binding PendingDeletionItemSummary}"
                                           FontSize="22"
                                           FontWeight="Semibold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SheetCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Space impact"
                                           FontSize="12"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                <TextBlock Text="{Binding PendingDeletionSizeDisplay}"
                                           FontSize="22"
                                           FontWeight="Semibold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SheetCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Categories"
                                           FontSize="12"
                                           Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                <TextBlock Text="{Binding PendingDeletionCategorySummary}"
                                           FontSize="22"
                                           FontWeight="Semibold"
                                           Foreground="{StaticResource CleanupSoftTextBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,20,0">
                            <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Categories selected"
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"/>
                        <ScrollViewer Margin="0,4,0,0"
                                      MaxHeight="160"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      IsDeferredScrollingEnabled="False"
                                      PanningMode="VerticalOnly"
                                      IsManipulationEnabled="True"
                                      Focusable="False">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer"
                                       BasedOn="{StaticResource App.ScrollViewerStyle}">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingDeletionCategories}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding PendingDeletionCategories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CategorySummaryChipStyle}">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="No categories selected."
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingDeletionCategories}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Risk callouts"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                        <ItemsControl ItemsSource="{Binding PendingDeletionRisks}"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,0,8"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CleanupSurfaceHighlightBrush}"/>
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource CleanupAccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Severity}"
                                                                 Value="{x:Static viewModels:CleanupDeletionRiskSeverity.Caution}">
                                                        <Setter Property="Background"
                                                                Value="#1E253C"/>
                                                        <Setter Property="BorderBrush"
                                                                Value="#FBBF24"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Severity}"
                                                                 Value="{x:Static viewModels:CleanupDeletionRiskSeverity.Danger}">
                                                        <Setter Property="Background"
                                                                Value="#2A1426"/>
                                                        <Setter Property="BorderBrush"
                                                                Value="#F87171"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No additional risks detected. You're good to go."
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   Margin="0,0,0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPendingDeletionRisks}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLockingProcessPanelVisible}"
                                                 Value="True">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Apps currently locking these files"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                        <TextBlock Text="{Binding LockingProcessSummary}"
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,12">
                            <Button Content="Rescan"
                                    Command="{Binding RefreshLockingProcessesCommand}"
                                    Style="{StaticResource FlatButtonStyle}"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="ViewLockingAppsButton"
                                    Content="{Binding LockingProcessButtonLabel}"
                                    Command="{Binding ShowLockingProcessesCommand}"
                                    Style="{StaticResource FlatButtonStyle}"
                                    IsEnabled="{Binding IsLockingProcessPanelVisible}"
                                    Margin="0"/>
                        </StackPanel>
                        <Popup Placement="Center"
                               PlacementTarget="{Binding ElementName=ViewLockingAppsButton}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               IsOpen="{Binding IsLockingProcessPopupOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <Border Background="{StaticResource CleanupSurfaceBrush}"
                                    BorderBrush="{StaticResource CleanupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0"
                                    MaxWidth="640"
                                    MaxHeight="560">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              IsDeferredScrollingEnabled="False"
                                              PanningMode="VerticalOnly"
                                              IsManipulationEnabled="True"
                                              Focusable="False"
                                              Padding="16"
                                              MaxHeight="540">
                                    <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Apps currently locking these files"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        <Button Content="Close"
                                                Command="{Binding HideLockingProcessesCommand}"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,8,0,0">
                                        <Button Content="Select all"
                                                Command="{Binding SelectAllLockingProcessesCommand}"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Clear selection"
                                                Command="{Binding ClearLockingProcessSelectionsCommand}"
                                                Style="{StaticResource FlatButtonStyle}"/>
                                    </StackPanel>
                                    <ScrollViewer Margin="0,12,0,0"
                                                  MaxHeight="360"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  IsDeferredScrollingEnabled="False"
                                                  PanningMode="VerticalOnly"
                                                  IsManipulationEnabled="True"
                                                  Focusable="False">
                                        <ItemsControl ItemsSource="{Binding LockingProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="10"
                                                            Padding="12"
                                                            Margin="0,0,0,8"
                                                            Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                                            BorderBrush="{StaticResource CleanupBorderBrush}"
                                                            BorderThickness="1">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <CheckBox Content="{Binding DisplayName}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          Style="{StaticResource App.CheckBoxStyle}"
                                                                          FontSize="13"
                                                                          Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                                                <Border Background="#332DD4BF"
                                                                        CornerRadius="8"
                                                                        Padding="8,2"
                                                                        Margin="8,0,0,0"
                                                                        Visibility="{Binding IsService, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="Service"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                                                </Border>
                                                                <Border Background="#33F87171"
                                                                        CornerRadius="8"
                                                                        Padding="8,2"
                                                                        Margin="8,0,0,0"
                                                                        Visibility="{Binding IsCritical, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="Critical"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding ImpactSummary}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                                                       Margin="0,4,0,0"/>
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                                                       Margin="0,2,0,0"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,12,0,0">
                                        <Button Content="Close selected apps"
                                                Command="{Binding CloseSelectedLockingProcessesCommand}"
                                                Style="{StaticResource FlatButtonStyle}"/>
                                        <Button Content="Force close selected"
                                                Command="{Binding ForceCloseSelectedLockingProcessesCommand}"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Margin="8,0,0,0"/>
                                        <Button Content="Close all apps"
                                                Command="{Binding CloseAllLockingProcessesCommand}"
                                                   Style="{StaticResource FlatButtonStyle}"
                                                   Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="Unsaved work may be lost when closing these apps. Force close should be a last resort."
                                                   FontSize="11"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            </StackPanel>
                        </StackPanel>
                           <StackPanel Grid.Column="1"
                                 Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,24,0,0">
                                <Button Content="Back to review"
                                        Command="{Binding DismissDeletionConfirmationCommand}"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Background="{StaticResource CleanupSurfaceBrush}"
                                        Margin="0"/>
                                <Button x:Name="RunCleanupButton"
                                        Content="Run cleanup"
                                        Command="{Binding ShowRunConfirmationPopupCommand}"
                                        Background="{StaticResource CleanupAccentBrushSecondary}"
                                        Foreground="#041225"
                                        FontWeight="Semibold"
                                        Padding="18,10"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Margin="12,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ConfirmRunBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled"
                                                         Value="False">
                                                    <Setter TargetName="ConfirmRunBorder"
                                                            Property="Opacity"
                                                            Value="0.6"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="ConfirmRunBorder"
                                                            Property="Background"
                                                            Value="#2DD4BF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.IsEnabled>
                                        <Binding Path="IsBusy"
                                                 Converter="{StaticResource InverseBooleanConverter}"/>
                                    </Button.IsEnabled>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    <Grid Panel.ZIndex="4"
          Background="#CC050D1F"
          Visibility="{Binding IsRunConfirmationPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          IsDeferredScrollingEnabled="False"
                          PanningMode="VerticalOnly"
                          IsManipulationEnabled="True"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True"
                          Margin="24"
                          Focusable="False">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="880"
                            Padding="36"
                            CornerRadius="28"
                            Background="{StaticResource CleanupSurfaceBrush}"
                            BorderBrush="{StaticResource CleanupBorderBrush}"
                            BorderThickness="1.5"
                            Effect="{StaticResource SurfaceShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="Ready to run cleanup?"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"/>
                            <TextBlock Text="{Binding PendingDeletionItemSummary, StringFormat={}Deleting {0} across selected categories.}"
                                       FontSize="13"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Adjust how OptiSys handles locked items, recycle bin usage, and reporting before committing the deletion."
                                       FontSize="13"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       Margin="0,6,0,18"
                                       TextWrapping="Wrap"/>
                            <ux:AdaptiveTilePanel MinColumnWidth="300"
                                                 MaxColumnWidth="420"
                                                 ColumnSpacing="24"
                                                 RowSpacing="24">
                                <Border Style="{StaticResource SheetCardStyle}"
                                        Padding="24"
                                        MinHeight="170">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Send to Recycle Bin when possible"
                                                  IsChecked="{Binding UseRecycleBin, Mode=TwoWay}"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  FontSize="14"/>
                                        <TextBlock Text="Move supported files into the Recycle Bin so they can be restored later. If Windows cannot stage a file, we keep it and report it."
                                                   FontSize="12"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SheetCardStyle}"
                                        Padding="24"
                                        MinHeight="170">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Skip files that are still locked"
                                                  IsChecked="{Binding SkipLockedItems, Mode=TwoWay}"
                                                  IsEnabled="{Binding RepairPermissionsBeforeDelete, Converter={StaticResource InverseBooleanConverter}}"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  FontSize="14"/>
                                        <TextBlock Text="Leave stubborn files in place when another app is still using them. This is the safest default and avoids interrupting background work."
                                                   FontSize="12"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SheetCardStyle}"
                                        Padding="24"
                                        MinHeight="190">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Force delete locked items"
                                                  IsChecked="{Binding RepairPermissionsBeforeDelete, Mode=TwoWay}"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  FontSize="14"/>
                                        <TextBlock Text="Take ownership, clear read-only flags, and remove locked files even if another process is holding them open. Overrides the Skip locked option."
                                                   FontSize="12"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Only enable this when you are certain the files are safe to delete."
                                                   FontSize="12"
                                                   Foreground="#FBBF24"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RepairPermissionsBeforeDelete}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Allow protected system locations (dangerous)"
                                                  IsChecked="{Binding IncludeProtectedSystemLocations, Mode=TwoWay}"
                                                  IsEnabled="{Binding RepairPermissionsBeforeDelete}"
                                                  Foreground="#FCA5A5"
                                                  FontSize="13"
                                                  Margin="0,12,0,0"
                                                  ToolTip="When enabled, files inside Windows and Program Files may be removed. Use only if you are absolutely sure.">
                                            <CheckBox.Resources>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </CheckBox.Resources>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SheetCardStyle}"
                                        Padding="24"
                                        MinHeight="170">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                  Content="Generate cleanup report"
                                                  IsChecked="{Binding GenerateCleanupReport, Mode=TwoWay}"
                                                  Foreground="{StaticResource CleanupSoftTextBrush}"
                                                  FontSize="14"/>
                                        <TextBlock Text="Create a detailed HTML report under Documents\\OptiSys\\Reports showing everything that was removed. Helpful for audits or support tickets."
                                                   FontSize="12"
                                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </ux:AdaptiveTilePanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,24,0,0">
                                <Button Content="Cancel"
                                        Command="{Binding HideRunConfirmationPopupCommand}"
                                        Style="{StaticResource FlatButtonStyle}"/>
                                <Button Content="Delete now"
                                        Command="{Binding ConfirmCleanupCommand}"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Padding="16,6">
                                    <Button.IsEnabled>
                                        <Binding Path="IsBusy"
                                                 Converter="{StaticResource InverseBooleanConverter}"/>
                                    </Button.IsEnabled>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>

    <!-- Preview Confirmation Popup -->
    <Grid Panel.ZIndex="5"
          Background="#CC050D1F"
          Visibility="{Binding IsPreviewConfirmationPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="440"
                    Height="280"
                    CornerRadius="20"
                    Background="{StaticResource CleanupSurfaceBrush}"
                    BorderBrush="{StaticResource CleanupBorderBrush}"
                    BorderThickness="1.5"
                    Effect="{StaticResource SurfaceShadowEffect}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="32">
                    <Border Width="52" Height="52"
                            Background="#2038BDF8"
                            CornerRadius="26"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <TextBlock Text="🔍"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Ready to scan?"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource CleanupSoftTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Analyze your system to find cleanup opportunities."
                               FontSize="13"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Cancel"
                                Command="{Binding HidePreviewConfirmationPopupCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                Padding="20,10"/>
                        <Button Content="Start scan"
                                Command="{Binding ConfirmAndRunPreviewCommand}"
                                Margin="12,0,0,0"
                                Background="{StaticResource CleanupAccentBrushSecondary}"
                                Foreground="#041225"
                                FontWeight="SemiBold"
                                Padding="20,10"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="StartScanBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="StartScanBorder" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="StartScanBorder" Property="Background" Value="#2DD4BF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <!-- Preview Scan Loading Overlay -->
    <Border Background="#CC020B1F"
            Visibility="{Binding IsPreviewScanInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
            IsHitTestVisible="{Binding IsPreviewScanInProgress}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="6"
            Focusable="False">
        <Grid>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource CleanupSurfaceElevatedBrush}"
                    BorderBrush="{StaticResource CleanupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="32"
                    Width="440"
                    Height="280"
                    Effect="{StaticResource SurfaceShadowEffect}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="52"
                            Height="52"
                            Background="#2038BDF8"
                            CornerRadius="26"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <TextBlock Text="🔍"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Scanning your system…"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource CleanupSoftTextBrush}"
                               Margin="0,0,0,6"
                               TextAlignment="Center"/>
                    <TextBlock Text="{Binding ScanProgressCategory, TargetNullValue='Analyzing cleanup targets'}"
                               FontSize="12"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="360"
                               Margin="0,0,0,8"/>
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               TextAlignment="Center"
                               Margin="0,0,0,16">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Scanned {0:N0} files ({1})">
                                <Binding Path="ScanProgressFilesScanned"/>
                                <Binding Path="ScanProgressBytesScanned" Converter="{StaticResource FileSizeConverter}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ProgressBar Height="6"
                                 Width="340"
                                 Value="{Binding ScanProgressCurrent}"
                                 Maximum="{Binding ScanProgressTotal}"
                                 IsIndeterminate="{Binding IsActiveOperationIndeterminate}"
                                 Foreground="#38BDF8"/>
                    <TextBlock Text="{Binding ActiveOperationPercentDisplay}"
                               FontSize="11"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               TextAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding HasActiveOperationPercent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>

    <!-- Cleanup Execution Loading Overlay -->
    <Border Background="#CC020B1F"
            Visibility="{Binding IsCleanupExecutionInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
            IsHitTestVisible="{Binding IsCleanupExecutionInProgress}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="6"
            Focusable="False">
        <Grid>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource CleanupSurfaceElevatedBrush}"
                    BorderBrush="{StaticResource CleanupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="40"
                    Width="480"
                    Height="320"
                    Effect="{StaticResource SurfaceShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <Border Width="60"
                                Height="60"
                                Background="#2034D399"
                                CornerRadius="30"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <TextBlock Text="🧹"
                                       FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Cleaning up…"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Progress Section -->
                    <StackPanel Grid.Row="1" 
                                VerticalAlignment="Center"
                                Margin="0,20,0,0">
                        <!-- Percentage Display -->
                        <TextBlock FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#34D399"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"
                                   Text="{Binding ActiveOperationPercentDisplay}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasActiveOperationPercent}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- Progress Bar -->
                        <Border Background="{StaticResource CleanupSurfaceBrush}"
                                CornerRadius="6"
                                Height="12"
                                ClipToBounds="True">
                            <ProgressBar Height="12"
                                         Value="{Binding DeletionProgressCurrent}"
                                         Maximum="{Binding DeletionProgressTotal}"
                                         IsIndeterminate="{Binding IsActiveOperationIndeterminate}"
                                         Foreground="#34D399"
                                         Background="Transparent"
                                         BorderThickness="0"/>
                        </Border>
                        
                        <!-- Status Text -->
                        <TextBlock Text="{Binding DeletionStatusMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="380"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                    
                    <!-- Item Count -->
                    <TextBlock Grid.Row="2"
                               FontSize="12"
                               Foreground="{StaticResource CleanupMutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center">
                        <Run Text="{Binding DeletionProgressCurrent, StringFormat={}{0:N0}}"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding DeletionProgressTotal, StringFormat={}{0:N0}}"/>
                        <Run Text=" items"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <!-- Modern Full-Screen Celebration UI -->
    <Border Background="#F0060F1F"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="3"
            Style="{StaticResource CelebrationOverlayStyle}"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True"
            RenderOptions.ClearTypeHint="Enabled"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType"
            TextOptions.TextHintingMode="Fixed">
        <Grid>
            <!-- Animated gradient background -->
            <Border CornerRadius="0"
                    Opacity="0.4">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.3" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#1A38BDF8" Offset="0"/>
                        <GradientStop Color="#0534D399" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
            
            <ScrollViewer HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          IsDeferredScrollingEnabled="False"
                          PanningMode="VerticalOnly"
                          PanningRatio="1"
                          IsManipulationEnabled="True"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True"
                          Focusable="False">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="32,48,32,48"
                      MaxWidth="880"
                      MinWidth="680">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Hero Section with Animation -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,32">
                        <controls:CleanupCelebrationView x:Name="CelebrationView"
                                                         Width="180"
                                                         Height="140"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,24"/>
                        <TextBlock Text="✨ Cleanup Complete!"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CelebrationDetails}"
                                   FontSize="15"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="500"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                    
                    <!-- Stats Cards using UniformGrid for equal sizing -->
                    <Border Grid.Row="1"
                            Margin="0,0,0,24">
                        <UniformGrid Rows="1" Columns="4">
                            <!-- Space Reclaimed Card -->
                            <Border Background="{StaticResource CleanupSurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource CleanupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16,20"
                                    Margin="0,0,8,0"
                                    Effect="{StaticResource CardShadowEffect}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="44" Height="44"
                                            Background="#2038BDF8"
                                            CornerRadius="22"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="💾"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding CelebrationReclaimedDisplay}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#38BDF8"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="Space freed"
                                               FontSize="11"
                                               Foreground="{StaticResource CleanupMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Items Removed Card -->
                            <Border Background="{StaticResource CleanupSurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource CleanupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16,20"
                                    Margin="4,0,4,0"
                                    Effect="{StaticResource CardShadowEffect}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="44" Height="44"
                                            Background="#2034D399"
                                            CornerRadius="22"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="🗑️"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding CelebrationItemsDeleted, StringFormat={}{0:N0}}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#34D399"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="Items removed"
                                               FontSize="11"
                                               Foreground="{StaticResource CleanupMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Categories Card -->
                            <Border Background="{StaticResource CleanupSurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource CleanupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16,20"
                                    Margin="4,0,4,0"
                                    Effect="{StaticResource CardShadowEffect}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="44" Height="44"
                                            Background="#20A855F7"
                                            CornerRadius="22"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="📂"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding CelebrationCategoryCount, StringFormat={}{0:N0}}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#A855F7"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="Categories"
                                               FontSize="11"
                                               Foreground="{StaticResource CleanupMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Time Saved Card -->
                            <Border Background="{StaticResource CleanupSurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource CleanupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="16,20"
                                    Margin="8,0,0,0"
                                    Effect="{StaticResource CardShadowEffect}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="44" Height="44"
                                            Background="#20F59E0B"
                                            CornerRadius="22"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="⏱️"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding CelebrationTimeSavedDisplay}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#F59E0B"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="Time saved"
                                               FontSize="11"
                                               Foreground="{StaticResource CleanupMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>
                    
                    <!-- Execution Summary -->
                    <Border Grid.Row="2"
                            Background="{StaticResource CleanupSurfaceBrush}"
                            BorderBrush="{StaticResource CleanupBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,14"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="Duration: "/>
                                <Run Text="{Binding CelebrationDurationDisplay}" Foreground="{StaticResource CleanupSoftTextBrush}" FontWeight="SemiBold"/>
                                <Run Text="  •  Skipped: "/>
                                <Run Text="{Binding CelebrationItemsSkipped, StringFormat={}{0:N0}}" Foreground="{StaticResource CleanupSoftTextBrush}" FontWeight="SemiBold"/>
                                <Run Text="  •  Failed: "/>
                                <Run Text="{Binding CelebrationItemsFailed, StringFormat={}{0:N0}}" Foreground="{StaticResource CleanupSoftTextBrush}" FontWeight="SemiBold"/>
                                <Run Text="  •  Pending reboot: "/>
                                <Run Text="{Binding CelebrationItemsPendingReboot, StringFormat={}{0:N0}}" Foreground="#F59E0B" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Main Content Card (Categories + Errors) -->
                    <Border Grid.Row="3"
                            Background="{StaticResource CleanupSurfaceElevatedBrush}"
                            BorderBrush="{StaticResource CleanupBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24"
                            Margin="0,0,0,24"
                            Effect="{StaticResource CardShadowEffect}"
                            Style="{StaticResource CelebrationPhaseContainerStyle}">
                        <StackPanel>
                            <!-- Categories Section -->
                            <TextBlock Text="Categories cleaned"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                       Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding CelebrationCategories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                                BorderBrush="{StaticResource CleanupBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,6"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCelebrationCategories}"
                                                         Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                            <TextBlock Text="No categories were affected."
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupMutedTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCelebrationCategories}"
                                                         Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Errors Section - Shows warning banner with Show All button -->
                            <Border Margin="0,16,0,0"
                                    Background="#20FBBF24"
                                    BorderBrush="#40FBBF24"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,12"
                                    Visibility="{Binding HasCelebrationFailures, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="⚠️"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FBBF24"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding CelebrationFailureCount, Mode=OneWay}"/>
                                            <Run Text=" item(s) couldn't be removed"/>
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2"
                                            Content="Show all"
                                            Command="{Binding ShowCelebrationErrorsPopupCommand}"
                                            Style="{StaticResource FlatButtonStyle}"
                                            Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                            Padding="14,8"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <!-- Success message when no failures -->
                            <Border Margin="0,16,0,0"
                                    Background="#1534D399"
                                    CornerRadius="8"
                                    Padding="14"
                                    Visibility="{Binding HasCelebrationFailures, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock Text="✓ All items were removed successfully!"
                                           FontSize="13"
                                           Foreground="#34D399"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Content="📋 Review report"
                                Command="{Binding ReviewCelebrationReportCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                IsEnabled="{Binding CanReviewCelebrationReport}"
                                Padding="16,10"
                                Margin="0,0,10,0"/>
                        <Button Content="📤 Share summary"
                                Command="{Binding ShareCelebrationSummaryCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                Padding="16,10"
                                Margin="0,0,10,0"/>
                        <Button Content="🏠 Back to dashboard"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource FlatButtonStyle}"
                                Background="{StaticResource CleanupSurfaceBrush}"
                                Padding="16,10"
                                Margin="0,0,10,0"/>
                        <Button Content="Done"
                                Command="{Binding CloseCelebrationCommand}"
                                Background="{StaticResource CleanupAccentBrushSecondary}"
                                Foreground="#041225"
                                FontWeight="SemiBold"
                                Padding="24,10"
                                Cursor="Hand"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="DoneBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DoneBorder" Property="Background" Value="#2DD4BF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
        </Border>

    <!-- Celebration Errors Popup -->
    <Grid Panel.ZIndex="7"
          Background="#DD050D1F"
          Visibility="{Binding IsCelebrationErrorsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="560"
                MaxHeight="520"
                Background="{StaticResource CleanupSurfaceElevatedBrush}"
                BorderBrush="{StaticResource CleanupBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Effect="{StaticResource SurfaceShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Border Grid.Row="0"
                        Padding="24,20"
                        BorderBrush="{StaticResource CleanupBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,8">
                            <TextBlock Text="⚠️"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Items that couldn't be removed"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   HorizontalAlignment="Center">
                            <Run Text="{Binding CelebrationFailureCount, Mode=OneWay}"/>
                            <Run Text=" files failed due to access restrictions or locks"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- Error List -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              IsDeferredScrollingEnabled="False"
                              PanningMode="VerticalOnly"
                              IsManipulationEnabled="True"
                              Focusable="False"
                              Padding="20,16">
                    <ItemsControl ItemsSource="{Binding CelebrationFailures}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CleanupSurfaceBrush}"
                                        BorderBrush="{StaticResource CleanupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32"
                                                Background="#20FBBF24"
                                                CornerRadius="16"
                                                VerticalAlignment="Top"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="!"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#FBBF24"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Reason}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Footer -->
                <Border Grid.Row="2"
                        Padding="20,16"
                        BorderBrush="{StaticResource CleanupBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Button Content="Close"
                            Command="{Binding HideCelebrationErrorsPopupCommand}"
                            HorizontalAlignment="Center"
                            Background="{StaticResource CleanupAccentBrushSecondary}"
                            Foreground="#041225"
                            FontWeight="SemiBold"
                            Padding="32,10"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBorder" Property="Background" Value="#2DD4BF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Border>
    </Grid>

        <Border Style="{StaticResource PhaseTransitionOverlayStyle}"
                Panel.ZIndex="60">
            <Grid>
                <Border Style="{StaticResource PhaseTransitionPanelStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="32,28"
                        CornerRadius="18"
                        Background="{StaticResource CleanupPhaseOverlayPanelBrush}"
                        BorderBrush="{StaticResource CleanupBorderBrush}"
                        BorderThickness="1.5"
                        Effect="{StaticResource SurfaceShadowEffect}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="320">
                        <TextBlock Text="🌀"
                                   FontSize="34"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding PhaseTransitionMessage}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CleanupSoftTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Hang tight while we prepare the next phase."
                                   FontSize="12"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,18"/>
                        <ProgressBar Height="6"
                                     IsIndeterminate="True"
                                     Foreground="{StaticResource CleanupProgressBrush}"
                                     Background="{StaticResource CleanupSurfaceBaseBrush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ FILES POPUP DIALOG ═══════════════ -->
        <Grid Background="#90000000"
              Visibility="{Binding IsFilesPopupVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              MouseDown="OnFilesDialogOverlayClick"
              Panel.ZIndex="70">
            <Border Width="720" MaxHeight="680" Margin="48" Padding="0"
                    Background="{StaticResource CleanupSurfaceElevatedBrush}" 
                    BorderBrush="{StaticResource CleanupBorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="24" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Effect="{StaticResource SurfaceShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="28,24,28,20" BorderBrush="{StaticResource CleanupBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="52" Height="52" CornerRadius="14" Margin="0,0,18,0"
                                    Background="{StaticResource CleanupSurfaceHighlightBrush}">
                                <TextBlock Text="📁" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedTarget.Category, FallbackValue=Files}" 
                                           FontSize="20" FontWeight="SemiBold" 
                                           Foreground="{StaticResource CleanupSoftTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding SelectedTarget.RemainingItemCount, StringFormat={}{0:N0} files, FallbackValue=0 files}"
                                               FontSize="13" Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    <TextBlock Text=" • " FontSize="13" Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedTarget.RemainingSizeMegabytes, StringFormat={}{0:F2} MB, FallbackValue=0 MB}"
                                               FontSize="13" Foreground="{StaticResource CleanupMutedTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Files List with Pagination -->
                    <Grid Grid.Row="1" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Pagination Controls -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,8,16,12">
                            <TextBlock Text="{Binding FilteredItems.Count, StringFormat={}{0} items visible}"
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupMutedTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="⟨ Prev"
                                    Command="{Binding PreviousPageCommand}"
                                    Margin="16,0,0,0"
                                    Padding="12,6"
                                    FontSize="12"
                                    Style="{StaticResource FlatButtonStyle}"
                                    IsEnabled="{Binding CanGoToPreviousPage}"/>
                            <TextBlock Text="{Binding PageDisplay}"
                                       FontSize="12"
                                       Foreground="{StaticResource CleanupSoftTextBrush}"
                                       Margin="8,0,8,0"
                                       VerticalAlignment="Center"/>
                            <Button Content="Next ⟩"
                                    Command="{Binding NextPageCommand}"
                                    Padding="12,6"
                                    FontSize="12"
                                    Style="{StaticResource FlatButtonStyle}"
                                    IsEnabled="{Binding CanGoToNextPage}"/>
                        </StackPanel>

                        <!-- Files ListView (virtualized) -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding FilteredItems}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  VirtualizingStackPanel.ScrollUnit="Pixel"
                                  SelectionMode="Single"
                                  Focusable="False">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,0,4,8" Cursor="Hand"
                                            Background="{StaticResource CleanupSurfaceBrush}"
                                            BorderBrush="{StaticResource CleanupBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16,14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource CleanupSurfaceHighlightBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource CleanupAccentBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                      Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="0,0,14,0"
                                                      VerticalAlignment="Center"
                                                      FocusVisualStyle="{x:Null}"/>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource CleanupSoftTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FullName}"/>
                                                <WrapPanel Margin="0,6,0,0">
                                                    <Border Style="{StaticResource CleanupMetaChipStyle}"
                                                            Background="{StaticResource CleanupChipSizeBackgroundBrush}"
                                                            BorderBrush="{StaticResource CleanupChipSizeBorderBrush}">
                                                        <TextBlock FontSize="11" Foreground="{StaticResource CleanupSoftTextBrush}">
                                                            <Run Text="Size • "/>
                                                            <Run Text="{Binding SizeMegabytes, Mode=OneWay, StringFormat={}{0:F2} MB}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Style="{StaticResource CleanupMetaChipStyle}"
                                                            Background="{StaticResource CleanupChipModifiedBackgroundBrush}"
                                                            BorderBrush="{StaticResource CleanupChipModifiedBorderBrush}">
                                                        <TextBlock FontSize="11" Foreground="{StaticResource CleanupSoftTextBrush}">
                                                            <Run Text="Modified • "/>
                                                            <Run Text="{Binding LastModifiedDisplay, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource CleanupMutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding FullName}"
                                                           ToolTip="{Binding FullName}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty State -->
                        <TextBlock Text="No files in this category."
                                   Grid.Row="1"
                                   Foreground="{StaticResource CleanupMutedTextBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Panel.ZIndex="1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Footer -->
                    <Border Grid.Row="2" Padding="20,16,20,20" BorderBrush="{StaticResource CleanupBorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="Select all"
                                        Command="{Binding SelectAllCurrentCommand}"
                                        Padding="14,8"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                        Foreground="{StaticResource CleanupSoftTextBrush}"
                                        Margin="0,0,8,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SelectBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SelectBorder" Property="Background" Value="{StaticResource CleanupAccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#041225"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="Clear selection"
                                        Command="{Binding ClearCurrentSelectionCommand}"
                                        Padding="14,8"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Background="{StaticResource CleanupSurfaceHighlightBrush}"
                                        Foreground="{StaticResource CleanupSoftTextBrush}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ClearBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ClearBorder" Property="Background" Value="{StaticResource CleanupAccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#041225"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            <Button Grid.Column="1" 
                                    Content="Done" 
                                    Command="{Binding CloseFilesPopupCommand}"
                                    Padding="24,10"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    Background="{StaticResource CleanupAccentBrush}"
                                    Foreground="#041225"
                                    FontWeight="SemiBold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DoneBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DoneBorder" Property="Background" Value="{StaticResource CleanupAccentBrushSecondary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
