<Page x:Class="OptiSys.App.Views.PackageMaintenancePage"
    x:Name="MaintenancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:viewModels="clr-namespace:OptiSys.App.ViewModels"
            xmlns:converters="clr-namespace:OptiSys.App.Converters"
            xmlns:controls="clr-namespace:OptiSys.App.Views"
            xmlns:ux="clr-namespace:OptiSys.App.Controls"
    mc:Ignorable="d"
    Title="Package maintenance"
    Background="{DynamicResource PageBackdropBrush}"
    FontFamily="Segoe UI Variable Text"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextHintingMode="Fixed"
    RenderOptions.ClearTypeHint="Enabled"
    RenderOptions.BitmapScalingMode="HighQuality"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
      d:DataContext="{d:DesignInstance Type=viewModels:PackageMaintenanceViewModel, IsDesignTimeCreatable=False}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:EnumEqualsConverter x:Key="EnumEqualsConverter"/>
        <converters:AlternationIndexToBrushConverter x:Key="MaintenanceAlternationBrushConverter"/>

        <LinearGradientBrush x:Key="PageBackdropBrush"
                             StartPoint="0,0"
                             EndPoint="0.7,1">
            <GradientStop Color="#050914" Offset="0"/>
            <GradientStop Color="#080F1F" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SurfaceBaseBrush" Color="#050B18"/>
        <SolidColorBrush x:Key="SurfaceCardBrush" Color="#0E1729"/>
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#121E35"/>
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#16233E"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#1F2C45"/>
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#263551"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C7D2FE"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8CA0C6"/>
        <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="#5B21B6"/>
        <SolidColorBrush x:Key="AccentInfoBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="AccentSuccessBrush" Color="#34D399"/>
        <SolidColorBrush x:Key="AccentWarningBrush" Color="#FBBF24"/>
        <SolidColorBrush x:Key="AccentDangerBrush" Color="#F87171"/>
        <SolidColorBrush x:Key="ChipNeutralBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="ChipNeutralBorderBrush" Color="#2F3F5B"/>
        <SolidColorBrush x:Key="ChipAccentBrush" Color="#312E81"/>
        <SolidColorBrush x:Key="ChipAccentBorderBrush" Color="#4338CA"/>
    <converters:StringLengthToFontSizeConverter x:Key="PackageNameFontSizeConverter"
                            LargeSize="15"
                            MediumSize="13"
                            SmallSize="11"/>
    <converters:StringLengthToFontSizeConverter x:Key="PackageDetailsFontSizeConverter"
                            LargeSize="20"
                            MediumSize="17"
                            SmallSize="15"
                            MinimumSize="13"/>

        <Style x:Key="AccentButtonStyle"
               TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8B5CF6" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="#F75573"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#D53F5C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F43F5E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#BE123C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VersionSelectorButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SelectorRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectorRoot" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                                <Setter TargetName="SelectorRoot" Property="BorderBrush" Value="{StaticResource AccentPrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SelectorRoot" Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
                                <Setter TargetName="SelectorRoot" Property="BorderBrush" Value="{StaticResource AccentPrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SelectorRoot" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VersionChipButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ChipNeutralBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource ChipNeutralBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipRoot" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipRoot" Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChipRoot" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VersionChipTemplate" DataType="{x:Type viewModels:PackageVersionOptionViewModel}">
            <Button Content="{Binding Display}"
                    Style="{StaticResource VersionChipButtonStyle}"
                    Command="{Binding DataContext.ApplyVersionSelectionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                    CommandParameter="{Binding}"/>
        </DataTemplate>

        <Style x:Key="MaintenanceNavToggleStyle"
               TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#90000000"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.35"/>
            </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaintenanceFilterCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="AutomationSectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <Style x:Key="AutomationSectionSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <Style x:Key="AutomationToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="14"/>
                            <Ellipse x:Name="Thumb"
                                     Width="22"
                                     Height="22"
                                     Fill="#F8FAFC"
                                     Margin="4,3,26,3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#7C3AED"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="26,3,4,3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="#1F2937"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#1F2937"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaintenanceCardListItemStyle"
               TargetType="ListViewItem">
            <Setter Property="Padding"
                Value="24"/>
            <Setter Property="Margin"
                    Value="0,12"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Container"
                                Background="{StaticResource SurfaceRaisedBrush}"
                                BorderBrush="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource MaintenanceAlternationBrushConverter}}"
                                BorderThickness="1.2"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}"
                                Opacity="0.95"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Container"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentInfoBrush}"/>
                                <Setter TargetName="Container"
                                        Property="Opacity"
                                        Value="1"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Container"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentPrimaryBrush}"/>
                                <Setter TargetName="Container"
                                        Property="Opacity"
                                        Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="Container"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaintenancePackageCardItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource MaintenanceCardListItemStyle}">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="170"/>
        </Style>

        <Style x:Key="MaintenanceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentInfoBrush}"/>
                    <Setter Property="BorderThickness" Value="1.3"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VersionChipSelectorStyle" TargetType="Button" BasedOn="{StaticResource VersionSelectorButtonStyle}">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipRoot"
                                Background="#1E1B4B"
                                BorderBrush="#5B21B6"
                                BorderThickness="1.2"
                                CornerRadius="18"
                                Padding="12,8"
                                SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel>
                                    <ContentPresenter />
                                </StackPanel>
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="14"
                                        Background="#6D28D9"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <Path Data="M 9 12 L 14 17 L 19 12"
                                          Stroke="#F8FAFC"
                                          StrokeThickness="1.8"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          RenderOptions.EdgeMode="Aliased" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipRoot" Property="BorderBrush" Value="#7C3AED" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipRoot" Property="Background" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChipRoot" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VersionChipDisplayStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#312E81"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="MaintenanceQueueItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource MaintenanceCardListItemStyle}">
            <Setter Property="Padding"
                    Value="18"/>
            <Setter Property="Margin"
                    Value="0,8"/>
        </Style>

        <Style x:Key="MaintenanceInfoChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ChipNeutralBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ChipNeutralBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,6,6,0"/>
        </Style>

        <Style x:Key="MaintenanceAccentChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource MaintenanceInfoChipStyle}">
            <Setter Property="Background" Value="{StaticResource ChipAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ChipAccentBorderBrush}"/>
        </Style>

        <Style x:Key="MaintenanceAlertChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource MaintenanceInfoChipStyle}">
            <Setter Property="Background" Value="#331927"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDangerBrush}"/>
        </Style>

        <Style x:Key="MaintenancePackageTitleBadgeStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10,18,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="MaintenancePackageTitleTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <DataTemplate x:Key="OperationDetailsTemplate"
                      DataType="{x:Type viewModels:PackageMaintenanceOperationViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding PackageDisplay}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,6,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusDisplay}"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#38BDF8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="Succeeded">
                                        <Setter Property="Foreground"
                                                Value="#22C55E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="Failed">
                                        <Setter Property="Foreground"
                                                Value="#F87171"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Message}"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"
                               MaxWidth="260"/>
                </StackPanel>

                  <ux:AdaptiveTilePanel Margin="0,8,0,0"
                               MinColumnWidth="140"
                               ColumnSpacing="10"
                               RowSpacing="6"
                               HorizontalAlignment="Left">
                    <TextBlock Text="{Binding EnqueuedAt, StringFormat=Enqueued · {0:t}}"
                               Foreground="#64748B"
                               FontSize="11"
                           Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StartedAt, StringFormat=Started · {0:t}}"
                               Foreground="#64748B"
                               FontSize="11"
                           Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StartedAt}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CompletedAt, StringFormat=Completed · {0:t}}"
                               Foreground="#64748B"
                               FontSize="11"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompletedAt}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Attempts}"
                               Foreground="#64748B"
                               FontSize="11"
                               Margin="0,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Attempts}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Attempts}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </ux:AdaptiveTilePanel>

                <Border Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,12,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="200">
                        <ItemsControl ItemsSource="{Binding DisplayLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.HasErrors, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="#F87171"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PackageDetailsTemplate"
                      DataType="{x:Type viewModels:PackageMaintenanceItemViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                           FontSize="{Binding DisplayName, Converter={StaticResource PackageDetailsFontSizeConverter}}"
                           FontWeight="Bold"
                           Foreground="#F8FAFC"
                           TextWrapping="Wrap"/>

                <ux:AdaptiveTilePanel Margin="0,10,0,0"
                                     MinColumnWidth="160"
                                     ColumnSpacing="12"
                                     RowSpacing="10">
                    <Border Background="#132032"
                            CornerRadius="8"
                            Padding="10,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Manager"
                                       Foreground="#94A3B8"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ManagerDisplay}"
                                       Foreground="#38BDF8"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#132032"
                            CornerRadius="8"
                            Padding="10,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Version"
                                       Foreground="#94A3B8"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding VersionDisplay}"
                                       Foreground="#E2E8F0"
                                       FontSize="13"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#132032"
                            CornerRadius="8"
                            Padding="10,8"
                            Visibility="{Binding HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Update"
                                       Foreground="#94A3B8"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Available"
                                       Foreground="#22C55E"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ux:AdaptiveTilePanel>

                <TextBlock Text="{Binding Summary}"
                           Foreground="#94A3B8"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="{Binding Summary, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <StackPanel Orientation="Vertical"
                            Margin="0,10,0,0">
                    <TextBlock Text="Tags"
                               FontSize="12"
                               Foreground="#CBD5F5"
                               Margin="0,0,0,4"
                               Visibility="{Binding TagsDisplay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding Tags}"
                                  Visibility="{Binding TagsDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ux:AdaptiveTilePanel MinColumnWidth="120"
                                                      ColumnSpacing="8"
                                                      RowSpacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E293B"
                                        CornerRadius="6"
                                        Padding="8,3"
                                        Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#E2E8F0"
                                               FontSize="11"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Orientation="Vertical"
                            Margin="0,10,0,0">
                    <TextBlock Text="Homepage"
                               FontSize="12"
                               Foreground="#CBD5F5"
                               Margin="0,0,0,4"
                               Visibility="{Binding Homepage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Homepage}"
                               Foreground="#38BDF8"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="{Binding Homepage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical"
                            Margin="0,12,0,0">
                    <TextBlock Text="Last action"
                               FontSize="12"
                               Foreground="#CBD5F5"/>
                    <TextBlock Text="{Binding LastOperationMessage}"
                               Foreground="#94A3B8"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#94A3B8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LastOperationSucceeded}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#22C55E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding LastOperationSucceeded}"
                                                 Value="False">
                                        <Setter Property="Foreground"
                                                Value="#F87171"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Vertical"
                            Margin="0,12,0,0">
                    <TextBlock Text="Target version (optional)"
                               FontSize="12"
                               Foreground="#CBD5F5"/>
                        <Button x:Name="TargetVersionSelectorAnchor"
                            Style="{StaticResource VersionChipSelectorStyle}"
                            Command="{Binding DataContext.ToggleVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Stretch">
                        <DockPanel>
                            <StackPanel Orientation="Vertical"
                                        DockPanel.Dock="Left"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{Binding TargetVersionLabel}"
                                           Foreground="#F8FAFC"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Choose a specific release or stay on latest"
                                           Foreground="#A5B4FC"
                                           FontSize="11"/>
                            </StackPanel>
                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="#312E81"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True">
                                <Path Data="M 9 14 L 18 21 L 27 14"
                                      Stroke="#F8FAFC"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      RenderOptions.EdgeMode="Aliased"/>
                            </Border>
                        </DockPanel>
                    </Button>
                                        <Popup PlacementTarget="{Binding Source={x:Reference MaintenancePage}}"
                                                     Placement="Center"
                                                     HorizontalOffset="0"
                                                     VerticalOffset="0"
                                                     StaysOpen="True"
                                                     PopupAnimation="Fade"
                                                     AllowsTransparency="True"
                                                     Focusable="False"
                                                     IsOpen="{Binding IsVersionPickerOpen, Mode=TwoWay}"
                                                     DataContext="{Binding DataContext, ElementName=TargetVersionSelectorAnchor}">
                                                <Grid Width="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                            Height="{Binding PlacementTarget.ActualHeight, RelativeSource={RelativeSource AncestorType=Popup}}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True"
                              RenderOptions.BitmapScalingMode="HighQuality"
                              RenderOptions.ClearTypeHint="Enabled"
                              TextOptions.TextRenderingMode="ClearType"
                              TextOptions.TextFormattingMode="Display">
                                                        <Rectangle Fill="#C0081420"
                                                                             HorizontalAlignment="Stretch"
                                                                             VerticalAlignment="Stretch"
                                                                             IsHitTestVisible="True"/>
                                                        <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                                        BorderBrush="#1E293B"
                                                                        BorderThickness="1"
                                                                        CornerRadius="20"
                                                                        Padding="28"
                                                                        MaxWidth="760"
                                                                        MinWidth="640"
                                                                        Width="680"
                                                                        MinHeight="360"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        KeyboardNavigation.TabNavigation="Cycle"
                                                                        SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="28"
                                                      ShadowDepth="0"
                                                      Color="#33000000"
                                                      Opacity="0.85"/>
                                </Border.Effect>
                                <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Select a version"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               DockPanel.Dock="Left"/>
                                    <StackPanel Orientation="Horizontal"
                                                DockPanel.Dock="Right">
                                        <Button Content="Refresh"
                                                Margin="0,0,8,0"
                                                Padding="10,4"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.RefreshVersionOptionsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Close"
                                                Padding="10,4"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.CloseVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="Pick from discovered releases, or type a custom version if you need a specific build."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,4,0,10"
                                           TextWrapping="Wrap"/>
                                <ProgressBar IsIndeterminate="True"
                                             Height="4"
                                             Foreground="#7C3AED"
                                             Background="#1E293B"
                                             Visibility="{Binding IsVersionLookupInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <ScrollViewer Margin="0,10,0,0"
                                              MaxHeight="320"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding VersionOptions}"
                                                  ItemTemplate="{StaticResource VersionChipTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ux:AdaptiveTilePanel MinColumnWidth="120"
                                                                      ColumnSpacing="8"
                                                                      RowSpacing="8"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{Binding VersionLookupError}"
                                           Foreground="{StaticResource AccentDangerBrush}"
                                           FontSize="11"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VersionLookupError}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VersionLookupError}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="No published versions were returned for this package."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasVersionOptions}" Value="False"/>
                                                        <Condition Binding="{Binding IsVersionLookupInProgress}" Value="False"/>
                                                        <Condition Binding="{Binding VersionLookupError}" Value="{x:Null}"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Custom version"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                    <TextBox Text="{Binding TargetVersion, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                             Margin="0,4,0,0"
                                             Style="{StaticResource App.TextBoxStyle}"
                                             ToolTip="Provide a specific version to install. Leave blank for the latest release."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,12,0,0"
                                            HorizontalAlignment="Right">
                                    <Button Content="Use latest"
                                            Margin="0,0,8,0"
                                            Padding="12,6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.ClearTargetVersionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Done"
                                            Padding="14,6"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Command="{Binding DataContext.CloseVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Popup>
                    <Border Style="{StaticResource VersionChipDisplayStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Target:" Foreground="#94A3B8" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding TargetVersionLabel}" Foreground="#E0E7FF" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ux:AdaptiveTilePanel Margin="0,20,0,0"
                                      MinColumnWidth="180"
                                      ColumnSpacing="16"
                                      RowSpacing="16">
                    <Button Content="Queue update"
                            Command="{Binding DataContext.QueueUpdateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}"
                            MinWidth="180"
                            Height="44"
                            Padding="18,8"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.Name="Queue update">
                        <Button.ToolTip>Queue update</Button.ToolTip>
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource AccentButtonStyle}">
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                                <Setter Property="IsEnabled"
                                        Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanUpdate}"
                                                 Value="False">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                        <Button Content="Remove"
                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}"
                            MinWidth="160"
                            Height="44"
                            Padding="18,8"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.Name="Remove">
                        <Button.ToolTip>Remove</Button.ToolTip>
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                                <Setter Property="IsEnabled"
                                        Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanRemove}"
                                                 Value="False">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                        <Button Content="Force cleanup"
                            Command="{Binding DataContext.ForceRemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}"
                            MinWidth="160"
                            Height="44"
                            Padding="18,8"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.Name="Force cleanup">
                        <Button.ToolTip>Force cleanup</Button.ToolTip>
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource DangerButtonStyle}">
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                                <Setter Property="IsEnabled"
                                        Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanForceRemove}"
                                                 Value="False">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </ux:AdaptiveTilePanel>
            </StackPanel>
        </DataTemplate>

        <SolidColorBrush x:Key="MaintenanceOverlayBackdropBrush" Color="#B30B1629"/>

        <SolidColorBrush x:Key="MaintenanceOverlayPanelBrush" Color="#0F1C2F"/>

        <DropShadowEffect x:Key="MaintenanceOverlayShadowEffect"
                          Color="#000000"
                          ShadowDepth="0"
                          BlurRadius="18"
                          Opacity="0.35"/>
    </Page.Resources>

    <Grid>
        <Grid x:Name="MainContentHost"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Opacity" Value="0.35"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <ScrollViewer x:Name="ContentScrollViewer"
                          Margin="32"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalContentAlignment="Stretch"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                <Grid x:Name="PageContentGrid"
                      MinWidth="0"
                      MaxWidth="1360"
                      HorizontalAlignment="Center"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="HeaderGrid"
                  Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderPrimaryColumn"
                                      Width="*"/>
                    <ColumnDefinition x:Name="HeaderSecondaryColumn"
                                      Width="Auto"/>
                </Grid.ColumnDefinitions>

                    <controls:PageTitleBar x:Name="HeaderSummaryPanel"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           Title="{Binding Headline}"
                                           Subtitle="{Binding SummaryText}"
                                           IconGlyph="🛠️"
                                           Margin="0,0,16,0"/>

            <StackPanel x:Name="HeaderActionHost"
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                <StackPanel x:Name="HeaderActionPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}">
                                <Button.IsEnabled>
                                    <Binding Path="IsBusy"
                                             Converter="{StaticResource InverseBooleanConverter}"/>
                                </Button.IsEnabled>
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="HeaderLastRefreshedText"
                                   Text="{Binding LastRefreshedDisplay}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
            </Grid>

            <Grid x:Name="MainLayoutGrid"
                  Grid.Row="1"
                  Margin="0,28,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid x:Name="PackagesViewHost">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}"
                                                 Value="{x:Static viewModels:MaintenanceViewSection.Packages}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel x:Name="PrimaryColumnHost">
                            <Border Style="{StaticResource CardBorderStyle}"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Vertical"
                                                Grid.Row="0"
                                                Margin="0,0,0,16">
                                        <TextBlock Text="Package filters"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Search packages, filter by manager, and queue updates faster."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <ux:AdaptiveTilePanel Grid.Row="1"
                                                         MinColumnWidth="260"
                                                         ColumnSpacing="24"
                                                         RowSpacing="18"
                                                         Padding="0,4,0,4">
                                        <Border Style="{StaticResource MaintenanceFilterCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Keyword"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8"/>
                                                <TextBox MinWidth="240"
                                                         Style="{StaticResource App.TextBoxStyle}"
                                                         ToolTip="Filter by package name, identifier, manager, or tag"
                                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=120}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MaintenanceFilterCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Manager"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8"/>
                                                <ComboBox MinWidth="220"
                                                          ItemsSource="{Binding ManagerFilters}"
                                                          SelectedItem="{Binding SelectedManager, Mode=TwoWay}"
                                                          Style="{StaticResource App.ComboBoxStyle}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MaintenanceFilterCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Scope"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8"/>
                                                <CheckBox Style="{StaticResource App.CheckBoxStyle}"
                                                          Content="Updates only"
                                                          IsChecked="{Binding UpdatesOnly, Mode=TwoWay}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MaintenanceFilterCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Bulk actions"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8"/>
                                                <Button Content="Queue selected"
                                                        MinWidth="200"
                                                        Height="44"
                                                        Command="{Binding QueueSelectedUpdatesCommand}"
                                                        Style="{StaticResource AccentButtonStyle}"/>
                                            </StackPanel>
                                        </Border>
                                    </ux:AdaptiveTilePanel>

                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Installed packages"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Review installed packages, then queue updates or removals right here."
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Select all"
                                                Command="{Binding SelectAllPackagesCommand}"
                                                Margin="16,0,0,0"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource SecondaryButtonStyle}">
                                            <Button.ToolTip>Select all packages shown in the list</Button.ToolTip>
                                        </Button>
                                    </Grid>

                                    <StackPanel Grid.Row="1"
                                                Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,0,8">
                                            <Button Content="{Binding WarningToggleLabel}"
                                                    Command="{Binding ToggleWarningsCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,4"
                                                    Visibility="{Binding HasWarnings, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Warnings}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="HasItems"
                                                                 Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding AreWarningsVisible}"
                                                                     Value="False">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                            BorderBrush="{StaticResource AccentPrimaryBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="14"
                                                            Margin="0,0,0,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="⚠"
                                                                       FontSize="16"
                                                                       Margin="0,0,10,0"
                                                                       Grid.Column="0"
                                                                       VerticalAlignment="Top"/>
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Grid.Column="1"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                        <Grid Grid.Row="2"
                                          Margin="0,16,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ListView x:Name="PackagesListView"
                                              Grid.Row="1"
                                              ItemsSource="{Binding PagedPackages}"
                                                  SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="#F8FAFC"
                                                  AlternationCount="5"
                                                                                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.CanContentScroll="True"
                                                  ScrollViewer.PanningMode="VerticalOnly"
                                                  ScrollViewer.IsDeferredScrollingEnabled="False"
                                                                                                    VirtualizingPanel.IsVirtualizing="True"
                                                                                                    VirtualizingPanel.VirtualizationMode="Recycling"
                                                                                                    VirtualizingPanel.ScrollUnit="Pixel"
                                                  VirtualizingPanel.CacheLength="2"
                                                                                                    UseLayoutRounding="True"
                                                                                                    SnapsToDevicePixels="True"
                                                                                                    Padding="0,0,16,0"
                                                                                                    Loaded="PackagesListView_Loaded"
                                                                                                    ItemContainerStyle="{StaticResource MaintenancePackageCardItemStyle}">
                                            <ListView.Style>
                                                <Style TargetType="ListView">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PagedPackages.Count}"
                                                                     Value="0">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListView.Style>
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:PackageMaintenanceItemViewModel}">
                                                    <Border Style="{StaticResource MaintenanceCardStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0"
                                                                      Style="{StaticResource App.CheckBoxStyle}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      VerticalAlignment="Top"
                                                                      Margin="0,4,16,0" />

                                                            <StackPanel Grid.Column="1">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="18"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap"
                                                                               TextTrimming="None" />
                                                                    <Border Margin="10,0,0,0"
                                                                            Style="{StaticResource MaintenanceAlertChipStyle}"
                                                                            Padding="10,5"
                                                                            Visibility="{Binding HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <TextBlock Text="Update available"
                                                                                   Foreground="{StaticResource AccentWarningBrush}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                        <Border Margin="10,0,0,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border" BasedOn="{StaticResource MaintenanceAccentChipStyle}">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding QueueStatus}" Value="">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding QueueStatus}" Value="{x:Null}">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding QueueStatus}"
                                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding VersionHeadline}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Text="{Binding VersionDetails}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap" />

                                                                <TextBlock Margin="0,10,0,0"
                                                                           Text="{Binding Summary}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Summary}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <ItemsControl Margin="0,10,0,0"
                                                                              ItemsSource="{Binding Tags}"
                                                                              Visibility="{Binding TagsDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <ux:AdaptiveTilePanel MinColumnWidth="120"
                                                                                                ColumnSpacing="8"
                                                                                                RowSpacing="8" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Style="{StaticResource MaintenanceInfoChipStyle}">
                                                                                <TextBlock Text="{Binding}"
                                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                                           FontSize="11" />
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <StackPanel Margin="0,14,0,0"
                                                                            MinWidth="220">
                                                                    <TextBlock Text="Target version (optional)"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="11" />
                                                                    <Button x:Name="ListTargetVersionSelector"
                                                                            Style="{StaticResource VersionChipSelectorStyle}"
                                                                            Command="{Binding DataContext.ToggleVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                            CommandParameter="{Binding}"
                                                                            Margin="0,6,0,0"
                                                                            HorizontalAlignment="Stretch">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding TargetVersionLabel}"
                                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold" />
                                                                            <TextBlock Text="Tap to choose a release"
                                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                                       FontSize="10" />
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Popup PlacementTarget="{Binding Source={x:Reference MaintenancePage}}"
                                                                           Placement="Center"
                                                                           StaysOpen="True"
                                                                           PopupAnimation="Fade"
                                                                           AllowsTransparency="True"
                                                                           Focusable="False"
                                                                           IsOpen="{Binding IsVersionPickerOpen, Mode=TwoWay}"
                                                                           DataContext="{Binding DataContext, ElementName=ListTargetVersionSelector}">
                                                                        <Grid Width="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                              Height="{Binding PlacementTarget.ActualHeight, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                              SnapsToDevicePixels="True"
                                                                              UseLayoutRounding="True"
                                                                              RenderOptions.BitmapScalingMode="HighQuality"
                                                                              RenderOptions.ClearTypeHint="Enabled"
                                                                              TextOptions.TextRenderingMode="ClearType"
                                                                              TextOptions.TextFormattingMode="Display">
                                                                            <Rectangle Fill="#C0081420"
                                                                                       HorizontalAlignment="Stretch"
                                                                                       VerticalAlignment="Stretch"
                                                                                       IsHitTestVisible="True" />
                                                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                                                    BorderBrush="#1E293B"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="20"
                                                                                    Padding="24"
                                                                                    MinWidth="520"
                                                                                    Width="560"
                                                                                    MaxWidth="640"
                                                                                    MinHeight="320"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    KeyboardNavigation.TabNavigation="Cycle"
                                                                                    SnapsToDevicePixels="True">
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect BlurRadius="28"
                                                                                                      ShadowDepth="0"
                                                                                                      Color="#33000000"
                                                                                                      Opacity="0.85" />
                                                                                </Border.Effect>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="Select a version"
                                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                                               FontSize="14"
                                                                                               FontWeight="SemiBold" />
                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,10,0,4">
                                                                                        <Button Content="Refresh"
                                                                                                Margin="0,0,8,0"
                                                                                                Padding="10,4"
                                                                                                Command="{Binding DataContext.RefreshVersionOptionsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                                CommandParameter="{Binding}">
                                                                                            <Button.Style>
                                                                                                <Style TargetType="Button"
                                                                                                       BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                                                    <Setter Property="Background" Value="#2563EB" />
                                                                                                    <Setter Property="Foreground" Value="#F8FAFC" />
                                                                                                </Style>
                                                                                            </Button.Style>
                                                                                        </Button>
                                                                                        <Button Content="Close"
                                                                                                Padding="10,4"
                                                                                                Command="{Binding DataContext.CloseVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                                CommandParameter="{Binding}">
                                                                                            <Button.Style>
                                                                                                <Style TargetType="Button"
                                                                                                       BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                                                    <Setter Property="Background" Value="#F97316" />
                                                                                                    <Setter Property="Foreground" Value="#F8FAFC" />
                                                                                                </Style>
                                                                                            </Button.Style>
                                                                                        </Button>
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="Pick a discovered release or enter a custom version below."
                                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                                               FontSize="11"
                                                                                               TextWrapping="Wrap" />
                                                                                    <ProgressBar IsIndeterminate="True"
                                                                                                 Height="4"
                                                                                                 Foreground="#7C3AED"
                                                                                                 Background="#1E293B"
                                                                                                 Margin="0,10,0,0"
                                                                                                 Visibility="{Binding IsVersionLookupInProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                                    <ScrollViewer Margin="0,12,0,0"
                                                                                                  MaxHeight="240"
                                                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                                                  VerticalScrollBarVisibility="Auto">
                                                                                        <ItemsControl ItemsSource="{Binding VersionOptions}"
                                                                                                      ItemTemplate="{StaticResource VersionChipTemplate}">
                                                                                            <ItemsControl.ItemsPanel>
                                                                                                <ItemsPanelTemplate>
                                                                                                    <ux:AdaptiveTilePanel MinColumnWidth="110"
                                                                                                                          ColumnSpacing="8"
                                                                                                                          RowSpacing="8" />
                                                                                                </ItemsPanelTemplate>
                                                                                            </ItemsControl.ItemsPanel>
                                                                                        </ItemsControl>
                                                                                    </ScrollViewer>
                                                                                    <TextBlock Text="{Binding VersionLookupError}"
                                                                                               Foreground="{StaticResource AccentDangerBrush}"
                                                                                               FontSize="11"
                                                                                               Margin="0,8,0,0"
                                                                                               TextWrapping="Wrap">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding VersionLookupError}" Value="{x:Null}">
                                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    </DataTrigger>
                                                                                                    <DataTrigger Binding="{Binding VersionLookupError}" Value="">
                                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                    <TextBlock Text="No published versions were returned for this package."
                                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                                               FontSize="11"
                                                                                               Margin="0,4,0,0"
                                                                                               TextWrapping="Wrap">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                                <Style.Triggers>
                                                                                                    <MultiDataTrigger>
                                                                                                        <MultiDataTrigger.Conditions>
                                                                                                            <Condition Binding="{Binding HasVersionOptions}" Value="False" />
                                                                                                            <Condition Binding="{Binding IsVersionLookupInProgress}" Value="False" />
                                                                                                            <Condition Binding="{Binding VersionLookupError}" Value="{x:Null}" />
                                                                                                        </MultiDataTrigger.Conditions>
                                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                                    </MultiDataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                    <StackPanel Margin="0,12,0,0">
                                                                                        <TextBlock Text="Custom version"
                                                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                                                   FontSize="11" />
                                                                                        <TextBox Text="{Binding TargetVersion, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                                                                                 Margin="0,4,0,0"
                                                                                                 Style="{StaticResource App.TextBoxStyle}"
                                                                                                 ToolTip="Provide a specific version to install. Leave blank for the latest release." />
                                                                                    </StackPanel>
                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,14,0,0"
                                                                                                HorizontalAlignment="Right">
                                                                                        <Button Content="Latest"
                                                                                                Margin="0,0,8,0"
                                                                                                Padding="12,6"
                                                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                                                Command="{Binding DataContext.ClearTargetVersionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                                CommandParameter="{Binding}" />
                                                                                        <Button Content="Done"
                                                                                                Padding="14,6"
                                                                                                Style="{StaticResource AccentButtonStyle}"
                                                                                                Command="{Binding DataContext.CloseVersionPickerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                                CommandParameter="{Binding}" />
                                                                                    </StackPanel>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </Grid>
                                                                    </Popup>
                                                                    <Border Style="{StaticResource VersionChipDisplayStyle}">
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="Target:" Foreground="#94A3B8" FontSize="11" Margin="0,0,6,0" />
                                                                            <TextBlock Text="{Binding TargetVersionLabel}" Foreground="#E0E7FF" FontSize="11" FontWeight="SemiBold" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"
                                                                        Margin="16,0,0,0">
                                                                <Button Content="Queue update"
                                                                        Width="150"
                                                                        Margin="0,0,0,10"
                                                                        Command="{Binding DataContext.QueueUpdateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                                            <Setter Property="Height" Value="40" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding CanUpdate}" Value="False">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="Remove"
                                                                        Width="150"
                                                                        Margin="0,0,0,10"
                                                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Height" Value="40" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding CanRemove}" Value="False">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="Force cleanup"
                                                                        Width="150"
                                                                        Margin="0,0,0,10"
                                                                        Command="{Binding DataContext.ForceRemoveCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                                                            <Setter Property="Height" Value="40" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding CanForceRemove}" Value="False">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="Details"
                                                                        Width="150"
                                                                        Command="{Binding DataContext.ShowPackageDetailsCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Height" Value="40" />
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <TextBlock Text="No packages match your filter."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Packages.Count}"
                                                                     Value="0">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <DockPanel Grid.Row="3"
                                               Margin="0,16,0,0">
                                        <TextBlock Text="{Binding LastRefreshedDisplay}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding SummaryText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   Margin="16,0,0,0"/>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="QueueViewHost">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}"
                                                 Value="{x:Static viewModels:MaintenanceViewSection.Queue}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel x:Name="SecondaryColumnHost">
                            <Border Style="{StaticResource CardBorderStyle}"
                                    Padding="20"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Maintenance queue"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Monitor pending operations, retry failures, and review history"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                        <ux:AdaptiveTilePanel Grid.Row="1"
                                                 Margin="0,14,0,0"
                                                 HorizontalAlignment="Left"
                                                 MinColumnWidth="160"
                                                 ColumnSpacing="12"
                                                 RowSpacing="12">
                                        <Button Content="Retry failed"
                                            Command="{Binding RetryFailedCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                        <Button Content="Clear completed"
                                            Command="{Binding ClearCompletedCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                        </ux:AdaptiveTilePanel>

                                    <ListView x:Name="OperationsListView"
                                              Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding Operations}"
                                              SelectedItem="{Binding SelectedOperation, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Foreground="#F8FAFC"
                                              AlternationCount="5"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.CanContentScroll="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingStackPanel.ScrollUnit="Pixel"
                                              ItemContainerStyle="{StaticResource MaintenanceQueueItemStyle}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding PackageDisplay}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   MaxWidth="220"/>
                                                        <TextBlock Text="{Binding StatusDisplay}"
                                                                   Margin="10,0,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground"
                                                                            Value="#38BDF8"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="Succeeded">
                                                                            <Setter Property="Foreground"
                                                                                    Value="#22C55E"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                 Value="Cancelled">
                                                                            <Setter Property="Foreground"
                                                                                Value="#FBBF24"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="Failed">
                                                                            <Setter Property="Foreground"
                                                                                    Value="#F87171"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Message}"
                                                               Foreground="#94A3B8"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding Attempts}"
                                                               Foreground="#64748B"
                                                               FontSize="11"
                                                               Margin="0,4,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Attempts}"
                                                                                 Value="{x:Null}">
                                                                        <Setter Property="Visibility"
                                                                                Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Attempts}"
                                                                                 Value="">
                                                                        <Setter Property="Visibility"
                                                                                Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,10,0,0">
                                                        <Button Content="Cancel"
                                                                Command="{Binding DataContext.CancelOperationCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button"
                                                                       BasedOn="{StaticResource DangerButtonStyle}">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPendingOrRunning}"
                                                                                     Value="True">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Content="Operation details"
                                                                Command="{Binding DataContext.ShowOperationDetailsCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="8,0,0,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button"
                                                                       BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPendingOrRunning}"
                                                                                     Value="False">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                </Grid>
                            </Border>

                            <TextBlock Text="No maintenance operations queued yet. Queue an update or removal to get started."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Operations.Count}"
                                                         Value="0">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <Grid x:Name="AutomationViewHost">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}"
                                                 Value="{x:Static viewModels:MaintenanceViewSection.Automation}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      DataContext="{Binding Automation}">
                            <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="Maintenance automation cockpit"
                                                   Style="{StaticResource AutomationSectionHeaderTextStyle}"/>
                                        <TextBlock Text="Choose which packages stay up to date automatically or let OptiSys handle every detected update."
                                                   Style="{StaticResource AutomationSectionSubtitleTextStyle}"
                                                   Margin="0,6,0,0"/>
                                        <WrapPanel Margin="0,16,0,0">
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="#1E293B"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10,6"
                                                    Margin="0,0,12,12">
                                                <TextBlock Text="{Binding InventorySummary}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="#1E293B"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10,6"
                                                    Margin="0,0,12,12">
                                                <TextBlock Text="{Binding SelectionSummary}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="#1E293B"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10,6"
                                                    Margin="0,0,12,12">
                                                <TextBlock Text="{Binding LastRunSummary}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,16,0,0">
                                            <Button Content="Refresh list"
                                                    Command="{Binding RefreshAutomationPackagesCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Background updates"
                                                       Style="{StaticResource AutomationSectionHeaderTextStyle}"/>
                                            <ToggleButton Margin="12,0,0,0"
                                                          Style="{StaticResource AutomationToggleSwitchStyle}"
                                                          IsChecked="{Binding IsAutomationEnabled, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   Style="{StaticResource AutomationSectionSubtitleTextStyle}"
                                                   Margin="0,6,0,16"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="Cadence"
                                                       Width="80"
                                                       Foreground="#94A3B8"
                                                       VerticalAlignment="Center"/>
                                            <ComboBox Width="220"
                                                      ItemsSource="{Binding IntervalOptions}"
                                                      SelectedValuePath="Minutes"
                                                      SelectedValue="{Binding IntervalMinutes, Mode=TwoWay}"
                                                      Style="{StaticResource App.ComboBoxStyle}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <CheckBox Content="Update all packages when new versions are available"
                                                  Style="{StaticResource App.CheckBoxStyle}"
                                                  IsChecked="{Binding UpdateAllPackages, Mode=TwoWay}"
                                                  Foreground="#F8FAFC"/>
                                        <Border Background="{StaticResource ChipAccentBrush}"
                                                BorderBrush="{StaticResource ChipAccentBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12,6"
                                                Margin="0,12,0,0"
                                                Visibility="{Binding HasPendingChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="You have unapplied automation changes."
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                            <Button Content="Apply changes"
                                                    Command="{Binding ApplyAutomationCommand}"
                                                    Style="{StaticResource AccentButtonStyle}"/>
                                            <Button Content="Run now"
                                                    Command="{Binding RunAutomationNowCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Margin="12,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}" Padding="24">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Auto-update targets"
                                                       Style="{StaticResource AutomationSectionHeaderTextStyle}"/>
                                            <Border Background="#1F2937"
                                                    CornerRadius="8"
                                                    Padding="10,2"
                                                    Margin="12,0,0,0">
                                                <TextBlock Text="{Binding PackageOptions.Count, StringFormat={}{0} packages}"
                                                           Foreground="{StaticResource AccentInfoBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SelectionSummary}"
                                                   Style="{StaticResource AutomationSectionSubtitleTextStyle}"
                                                   Margin="0,6,0,12"/>

                                        <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                                            <TextBlock Text="Search packages"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Margin="0,0,0,6"/>
                                            <TextBox MinWidth="280"
                                                     Style="{StaticResource App.TextBoxStyle}"
                                                     ToolTip="Filter automation targets by name, identifier, or manager"
                                                     Text="{Binding PackageSearchText, UpdateSourceTrigger=PropertyChanged, Delay=120}"/>
                                        </StackPanel>

                                        <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,0,0,12"
                                                Visibility="{Binding IsRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ProgressBar Width="140" Height="6" IsIndeterminate="True"/>
                                                <TextBlock Text="Refreshing inventory..."
                                                           Margin="12,0,0,0"
                                                           Foreground="#CBD5F5"/>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding FilteredPackageOptions}" Margin="0,0,0,12">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ux:AdaptiveTilePanel MinColumnWidth="280"
                                                                          ColumnSpacing="16"
                                                                          RowSpacing="16"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:MaintenanceAutomationPackageOptionViewModel}">
                                                    <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                            BorderBrush="#1E293B"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="16">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#E2E8F0"
                                                                               TextWrapping="Wrap"/>
                                                                    <Border Background="#1F2937"
                                                                            CornerRadius="8"
                                                                            Padding="8,2"
                                                                            Margin="8,0,0,0"
                                                                            Visibility="{Binding RequiresAdministrator, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <TextBlock Text="Admin"
                                                                                   Foreground="#FACC15"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Manager}"
                                                                           Foreground="#94A3B8"
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0"/>
                                                                <TextBlock Text="{Binding VersionSummary}"
                                                                           Foreground="#CBD5F5"
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center">
                                                                <ToggleButton Style="{StaticResource AutomationToggleSwitchStyle}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                              IsEnabled="{Binding DataContext.UpdateAllPackages, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource InverseBooleanConverter}}"/>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           FontSize="11"
                                                                           HorizontalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Off"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                    <Setter Property="Text" Value="Auto-update"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentSuccessBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="No packages are available yet. Refresh the list to import inventory.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource AutomationSectionSubtitleTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PackageOptions.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="No packages match your search criteria."
                                                   Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource AutomationSectionSubtitleTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasPackageOptions}" Value="True"/>
                                                                <Condition Binding="{Binding HasFilteredPackages}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
        </Grid>

        <!-- Sticky pager overlay for reliable access to pagination controls -->
        <Border HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="32"
            Padding="10,8"
            Background="#1A2233"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource MaintenanceOverlayShadowEffect}"
            Panel.ZIndex="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasMultiplePages}" Value="True"/>
                                <Condition Binding="{Binding ActiveSection}" Value="{x:Static viewModels:MaintenanceViewSection.Packages}"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal"
                Margin="0,0,10,0"
                VerticalAlignment="Center">
            <TextBlock Text="{Binding PageDisplay}"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="12"
                   VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal"
                    Margin="12,0,0,0">
                <Button Content="Previous"
                    Command="{Binding GoToPreviousPageCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding CanGoToPreviousPage}"/>
                <Button Content="Next"
                    Command="{Binding GoToNextPageCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,6"
                    IsEnabled="{Binding CanGoToNextPage}"/>
            </StackPanel>
            </StackPanel>
        </Border>

        <Grid x:Name="PackageDetailsOverlay"
              Panel.ZIndex="12"
              Background="#B0101F33"
              Visibility="{Binding IsPackageDetailsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              IsHitTestVisible="{Binding IsPackageDetailsVisible}">
            <Border MaxWidth="720"
                    Margin="32"
                    Padding="24"
                                        Background="{StaticResource SurfaceCardBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16"
                               LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="54"
                                    Height="54"
                                    CornerRadius="18"
                                    Background="#132032"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPackage}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SelectedPackage.DisplayInitial}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#F8FAFC"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedPackage.DisplayName, TargetNullValue=Package details}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPackage.ManagerDisplay}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="Close"
                                Command="{Binding ClosePackageDetailsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                DockPanel.Dock="Right"
                                Padding="10,4"
                                MinWidth="72"
                                HorizontalAlignment="Right"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="440">
                            <ContentControl Content="{Binding SelectedPackage}"
                                            ContentTemplate="{StaticResource PackageDetailsTemplate}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPackage}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </ScrollViewer>

                        <TextBlock Text="Select a package to view its full details."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPackage}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="OperationDetailsOverlay"
              Panel.ZIndex="13"
              Background="#B00A1528"
              Visibility="{Binding IsOperationDetailsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
              IsHitTestVisible="{Binding IsOperationDetailsVisible}">
            <Border MaxWidth="760"
                    Margin="32"
                    Padding="24"
                                        Background="{StaticResource SurfaceCardBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16"
                               LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding SelectedOperation.PackageDisplay, TargetNullValue=Operation details}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SelectedOperation.StatusDisplay}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Content="Close"
                                Command="{Binding CloseOperationDetailsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                DockPanel.Dock="Right"
                                Padding="10,4"
                                MinWidth="72"
                                HorizontalAlignment="Right"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="480">
                            <ContentControl Content="{Binding SelectedOperation}"
                                            ContentTemplate="{StaticResource OperationDetailsTemplate}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedOperation}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </ScrollViewer>

                        <TextBlock Text="Select a completed operation to inspect its transcript."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedOperation}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ContentControl x:Name="MaintenanceLoadingOverlay"
                        Panel.ZIndex="15"
                        Focusable="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <ContentControl.Template>
                <ControlTemplate TargetType="ContentControl">
                    <Grid Background="{StaticResource MaintenanceOverlayBackdropBrush}"
                          Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsHitTestVisible="{Binding IsBusy}">
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="24,20"
                                CornerRadius="16"
                                Background="{StaticResource MaintenanceOverlayPanelBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1"
                                Effect="{StaticResource MaintenanceOverlayShadowEffect}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar Width="180"
                                             Height="10"
                                             IsIndeterminate="True"
                                             Foreground="#38BDF8"
                                             Background="#0E1C30"
                                             BorderBrush="#1F2E46"/>
                                <TextBlock Text="Preparing maintenance..."
                                           Margin="0,12,0,0"
                                           Foreground="#E5E7EB"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Auditing packages and queueing fixes"
